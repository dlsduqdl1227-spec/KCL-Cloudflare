{
  "name": "kcl-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --d1 DB=kcl-cloudflare --compatibility-date=2025-08-01",
    "deploy": "wrangler pages deploy public",
    "d1:create": "wrangler d1 create kcl-cloudflare",
    "d1:migrate:local": "wrangler d1 migrations apply kcl-cloudflare --local",
    "d1:migrate:remote": "wrangler d1 migrations apply kcl-cloudflare --remote"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}
