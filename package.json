{
  "name": "kcl-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:schema": "wrangler d1 execute DB --local --file=src/worker/db/schema.sql",
    "db:schema:remote": "wrangler d1 execute DB --remote --file=src/worker/db/schema.sql",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1",
    "wrangler": "^3.114.0"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2"
  }
}
